{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api(?:/|$)|robots\\.txt|sitemap\\.xml|googlee75b9d0f2bce7b3d\\.html|favicon\\.png|.*\\.js$|.*\\.css$|.*\\.png$|.*\\.jpg$|.*\\.ico$).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*).jsx",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        }
      ]
    }
  ]
}
